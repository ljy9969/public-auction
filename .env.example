# Optional: Kakao REST API for geocoding and transit (more accurate)
KAKAO_REST_API_KEY=

# AI 예상 낙찰가 (상세 페이지 'AI 예상가' 버튼) — 둘 중 하나만 있으면 동작.
#  - ANTHROPIC_API_KEY 있으면 Claude(기본, 품질 우선)
#  - GEMINI_API_KEY 있으면 Gemini(OctaLink 키 재사용 가능, 저렴/무료티어)
#  - AI_PROVIDER=claude|gemini 로 강제 선택 가능
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
# AI_PROVIDER=gemini   # Claude 키도 있을 때 Gemini로 강제하려면 주석 해제

# SQLite path (default: data/onbid.db)
ONBID_DB_PATH=data/onbid.db

# API server
API_HOST=0.0.0.0
API_PORT=8000
