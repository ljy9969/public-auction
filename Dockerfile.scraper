FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt scraper/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r scraper/requirements.txt \
    && playwright install chromium --with-deps
COPY shared ./shared
COPY scraper ./scraper
ENV PYTHONPATH=/app
CMD ["python", "-m", "scraper.run", "--max-pages", "5"]
